# Copy to .env and fill in. All are optional — without them the core pipeline
# (discover + extract + image overlay + local CSV) still runs and is verifiable.

# --- Google (Sheets + Drive) ---
# OAuth "Desktop app" client from Google Cloud Console > APIs & Services > Credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Target spreadsheet (already set to the sheet in the spec; override if needed).
SHEET_ID=1DdlgU8jLblCrsxkoYo0KDDtAfspdY8hmPFncSLoi67I
SHEET_GID=1314990366

# Optional: a Drive folder ID to upload into. If empty, a new folder is created.
DRIVE_PARENT_FOLDER_ID=

# Optional: email to grant access to the uploaded Drive folder (e.g. a teammate).
DRIVE_SHARE_WITH_EMAIL=

# --- Klaviyo (optional, only used with --use-klaviyo) ---
# The live /usa/ site does NOT expose per-template Klaviyo URLs, so this is off by
# default. If you have a name->URL/ID mapping, put it in klaviyo-map.json (see README).
