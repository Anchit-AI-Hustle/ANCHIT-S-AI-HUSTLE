# Copy to .env. The app RUNS without any of these (chat falls back to a built-in
# streaming "demo mode"). Add them to enable the real AI + a deployed backend.

# --- AI (server-only — never exposed to the device bundle) ---
# Vercel AI Gateway key. Get one at https://vercel.com/dashboard (AI Gateway).
# On Vercel deployments you can skip this and rely on the auto-injected
# VERCEL_OIDC_TOKEN (run `vercel link` + `vercel env pull` locally to use it).
AI_GATEWAY_API_KEY=

# Exact Gateway model slugs (see your AI Gateway dashboard for current ids).
AI_MODEL_PREMIUM=anthropic/claude-sonnet-4.5
AI_MODEL_FAST=anthropic/claude-haiku-4.5

# --- Client → backend origin (exposed to the app; safe, no secrets) ---
# In `expo start` dev this is auto-detected from the bundler host, so leave blank.
# For store builds, set this to your deployed server URL (EAS Hosting / Vercel),
# e.g. https://vahdam-superapp.vercel.app
EXPO_PUBLIC_API_URL=
